    </div>

    <div class="w-full flex flex-col gap-4">
      {links.map((link) => (
        <a 
          href={link.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col justify-center items-center w-full min-h-16 p-4 bg-[#111] hover:bg-[#161616] border border-neutral-800 rounded-2xl transition-all hover:scale-[1.02] hover:border-neutral-700 text-center"
        >
          <span class="text-white font-medium">{link.title}</span>
          {link.desc && (
            <span class="text-neutral-500 text-xs mt-1 font-mono">{link.desc}</span>
          )}
        </a>
      ))}
    </div>
    
  </div>
</BaseLayout>