---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

const allPosts = await getCollection('writings') as CollectionEntry<'writings'>[];
const sortedPosts = allPosts.sort((a: CollectionEntry<'writings'>, b: CollectionEntry<'writings'>) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<BaseLayout pageTitle="Rafif Muchsin">
  <div class="space-y-12">
    {sortedPosts.map((post: CollectionEntry<'writings'>) => (
      <a href={`/writings/${post.slug}`} class="block group">
        <h2 class="text-xl font-semibold text-neutral-200 group-hover:text-white group-hover:underline decoration-2 underline-offset-4 transition-all">
          {post.data.title}
        </h2>
        <div class="text-sm text-neutral-500 font-mono mt-2">{post.data.date}</div>
      </a>
    ))}
  </div>
</BaseLayout>
