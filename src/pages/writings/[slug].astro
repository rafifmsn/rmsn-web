---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostHeader from '../../components/PostHeader.astro';

export async function getStaticPaths() {
  const writingEntries = await getCollection('writings');
  return writingEntries.map((entry: CollectionEntry<'writings'>) => ({
    params: { slug: entry.slug }, 
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'writings'> };
const { Content } = await entry.render();
---

<BaseLayout pageTitle={entry.data.title} pageDescription={entry.data.summary || entry.data.title}>
  <article class="prose prose-invert prose-neutral max-w-none">
    <PostHeader title={entry.data.title} subtitle={entry.data.date} />
    <Content />
  </article>
</BaseLayout>