---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'writings'>[];
  limit?: number;
  showSummary?: boolean;
}

const { posts, limit, showSummary = true } = Astro.props;
const displayPosts = limit ? posts.slice(0, limit) : posts;
---

<div class="grid gap-8">
  {displayPosts.map((post) => (
    <a href={`/writings/${post.slug}`} class="group block">
      <article class="flex flex-col space-y-2">
        <div class="flex flex-col justify-between space-y-2">
          <h2 class="text-xl font-semibold text-neutral-200 group-hover:text-white group-hover:underline decoration-2 underline-offset-4 transition-all">
            {post.data.title}
          </h2>
          <time class="font-mono text-sm text-neutral-500 shrink-0">
            {post.data.date}
          </time>
        </div>
        {showSummary && post.data.summary && (
          <p class="text-neutral-400 text-sm leading-relaxed max-w-2xl">
            {post.data.summary}
          </p>
        )}
      </article>
    </a>
  ))}
</div>