---
const pathname = Astro.url.pathname;
const normalize = (path: string) => path.replace(/\/$/, "");
const currentPath = normalize(pathname);

// Active State Logic
const isWritings = currentPath === "" || currentPath.startsWith("/writings");
const isAbout = currentPath === "/about";
// Check if we are on ANY tools page
const isTools = currentPath.startsWith("/reader") || currentPath.startsWith("/encoder");
---

<header class="relative z-50">
  <div class="flex flex-wrap justify-between items-center py-4">
    
    <a href="/" class="font-sans font-bold text-lg tracking-tight hover:opacity-80 transition-opacity whitespace-nowrap z-50 relative">
      Rafif Muchsin
    </a>

    <nav class="hidden md:flex items-center gap-6 font-mono text-sm">
      <a 
        href="/writings" 
        class:list={[
          "transition-colors decoration-2 underline-offset-8", 
          isWritings ? "text-white underline" : "text-neutral-500 hover:text-white"
        ]}
      >
        Writings
      </a>

      <a 
        href="/about" 
        class:list={[
          "transition-colors decoration-2 underline-offset-8", 
          isAbout ? "text-white underline" : "text-neutral-500 hover:text-white"
        ]}
      >
        About
      </a>

      <div class="relative group">
        <button 
          class:list={[
            "flex items-center gap-1 transition-colors decoration-2 underline-offset-8 outline-none", 
            isTools ? "text-white underline" : "text-neutral-500 hover:text-white"
          ]}
        >
          Others
          <svg class="w-3 h-3 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
        </button>

        <div class="absolute right-0 top-full pt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform origin-top-right">
          <div class="bg-[#111] border border-neutral-800 rounded-xl p-2 w-48 shadow-2xl flex flex-col gap-1">
            <a href="/reader" class="px-4 py-2 hover:bg-[#222] rounded-lg text-neutral-400 hover:text-white transition-colors text-left flex items-center gap-2">
              <i class="iconoir-book"></i> Reader
            </a>
            <a href="/encoder" class="px-4 py-2 hover:bg-[#222] rounded-lg text-neutral-400 hover:text-white transition-colors text-left flex items-center gap-2">
              <i class="iconoir-code"></i> Encoder
            </a>
            <a href="/links" class="px-4 py-2 hover:bg-[#222] rounded-lg text-neutral-400 hover:text-white transition-colors text-left flex items-center gap-2">
              <i class="iconoir-link"></i> Links
            </a>
          </div>
        </div>
      </div>

    </nav>

    <button id="mobile-menu-btn" class="md:hidden z-50 text-neutral-400 hover:text-white transition-colors relative w-8 h-8 flex items-center justify-center">
      <span class="sr-only">Toggle menu</span>
      <svg id="icon-menu" class="w-6 h-6 absolute transition-all duration-300 transform scale-100 opacity-100" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
      <svg id="icon-close" class="w-6 h-6 absolute transition-all duration-300 transform scale-50 opacity-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-brand-dark/95 backdrop-blur-xl z-40 translate-x-full transition-transform duration-300 ease-in-out md:hidden flex flex-col overflow-x-scroll">
    <nav class="font-mono text-xl mt-16 px-6 py-12">
      <div class="flex flex-col gap-4 mb-8">
        <a href="/writings" class="text-neutral-400 hover:text-white transition-colors">Writings</a>
        <a href="/about" class="text-neutral-400 hover:text-white transition-colors">About</a>
      </div>
      <div class="flex flex-col gap-4 border-t border-neutral-800/50 py-6">
        <span class="text-xs font-bold text-neutral-600 uppercase tracking-widest">Tools</span>
        <a href="/reader" class="text-neutral-300 hover:text-white">Reader</a>
        <a href="/encoder" class="text-neutral-300 hover:text-white">Encoder</a>
        <a href="/links" class="text-neutral-300 hover:text-white">Links</a>
      </div>
    </nav>
  </div>
</header>

<script>
  // Mobile Menu Logic
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconMenu = document.getElementById('icon-menu');
  const iconClose = document.getElementById('icon-close');
  const body = document.body;

  let isMenuOpen = false;

  btn?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    
    if (isMenuOpen) {
      // Show menu, show X, HIDE hamburger completely
      menu?.classList.remove('translate-x-full');
      body.style.overflow = 'hidden';
      iconMenu?.classList.add('opacity-0', 'scale-50');
      iconMenu?.classList.remove('opacity-100', 'scale-100');
      iconClose?.classList.add('opacity-100', 'scale-100');
      iconClose?.classList.remove('opacity-0', 'scale-50');
    } else {
      // Hide menu, show hamburger, HIDE X completely
      menu?.classList.add('translate-x-full');
      body.style.overflow = '';
      iconMenu?.classList.add('opacity-100', 'scale-100');
      iconMenu?.classList.remove('opacity-0', 'scale-50');
      iconClose?.classList.add('opacity-0', 'scale-50');
      iconClose?.classList.remove('opacity-100', 'scale-100');
    }
  });

  // Close menu when clicking a link
  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      isMenuOpen = false;
      menu?.classList.add('translate-x-full');
      body.style.overflow = '';
      // Reset to hamburger state
      iconMenu?.classList.add('opacity-100', 'scale-100');
      iconMenu?.classList.remove('opacity-0', 'scale-50');
      iconClose?.classList.add('opacity-0', 'scale-50');
      iconClose?.classList.remove('opacity-100', 'scale-100');
    });
  });

</script>