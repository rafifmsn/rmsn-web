---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostHeader from '../components/PostHeader.astro';

export async function getStaticPaths() {
  const pageEntries = await getCollection('pages');
  return pageEntries.map((entry: CollectionEntry<"pages">) => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<"pages"> };
const { Content } = await entry.render();
---

<BaseLayout pageTitle={entry.data.title} pageDescription={entry.data.description}>
  <article class="prose prose-invert prose-neutral max-w-none">
    <PostHeader title={entry.data.title} subtitle={entry.data.description} />
    <Content />
  </article>
</BaseLayout>