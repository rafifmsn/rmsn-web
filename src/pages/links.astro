---
import BaseLayout from '../layouts/BaseLayout.astro';

// Add your specific links here
const links = [ // use `desc: null,` for an empty desc
  { 
    title: "Inquiries & Support Form",
    desc: null,
    url: "https://tally.so/r/mBRVXe" 
  },
  { 
    title: "Schedule a Meeting", 
    desc: null,
    url: "https://cal.com/rafifmsn/30min" 
  },
  { 
    title: "Payment for Services", 
    desc: "Credit/Debit/Crypto",
    url: "https://pay.rafifmsn.com/" 
  },
];
---

<BaseLayout pageTitle="Links">

  <div class="flex flex-col items-center w-full max-w-md mx-auto">
    
    <img 
      src="/profile.webp" 
      alt="Profile" 
      class="w-32 h-32 rounded-full border-2 border-neutral-800 mb-6 object-cover filter grayscale"
    />
    
    <h1 class="text-xl font-bold text-white mb-2">Rafif Muchsin</h1>
    <p class="text-neutral-400 text-sm text-center mb-6 leading-relaxed">
      rafif@rafifmsn.com
    </p>

    <div class="flex gap-6 mb-10 text-neutral-400">
      <a href="https://x.com/rafifmsn" class="hover:text-white transition-colors"><svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" id="X--Streamline-Simple-Icons" height="24" width="24" style="background-color: #0a0a0a"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8 -7.584 -6.638 7.584H0.474l8.6 -9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z" fill="#ffffff" stroke-width="1"></path></svg></a>
