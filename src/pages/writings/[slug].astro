---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('writings');
  return blogEntries.map((entry: CollectionEntry<'writings'>) => ({
    params: { slug: entry.slug }, 
    props: { entry }
  }));
}

const { entry } = Astro.props as { entry: CollectionEntry<'writings'> };
const { Content } = await entry.render();
---

<BaseLayout pageTitle={entry.data.title} pageDescription={entry.data.summary || entry.data.title}>
  <article class="prose prose-invert prose-neutral max-w-none">
    <header class="mb-12 border-b border-neutral-800 pb-8">
      <h1 class="text-2xl font-bold text-white mb-2">{entry.data.title}</h1>
      {entry.data.date && (
        <p class="text-neutral-500 text-base mt-4 italic">
          {entry.data.date}
        </p>
      )}
    </header>
    
    <Content />
  </article>
</BaseLayout>